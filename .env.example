# Solana RPC Configuration
# Copy this file to .env and update with your values

# Helius RPC endpoint with API key
# Get your API key at https://helius.xyz/
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Network configuration (mainnet or devnet)
VITE_SOLANA_NETWORK=mainnet

# Optional: Referral account for Jupiter fees (if registered)
# VITE_JUPITER_REFERRAL_ACCOUNT=YOUR_WALLET_ADDRESS

# Optional: Platform fee in basis points (if eligible)
# VITE_JUPITER_FEE_BPS=50